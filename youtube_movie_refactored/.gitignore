# ════════════════════════════════════════
# youtube_unified — .gitignore
# GitHub에 올리면 안 되는 파일 목록
# ════════════════════════════════════════


# ──────────────────────────────────────
# 🔴 Python 캐시 (자동 생성, 불필요)
# ──────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyc
*$py.class


# ──────────────────────────────────────
# 🔴 테스트 캐시
# ──────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml


# ──────────────────────────────────────
# 🔴 처리 결과물 (용량 크고 개인 데이터)
# ──────────────────────────────────────
video_projects/
batch_reports/
*.mp4
*.mp3
*.mkv
*.avi
*.mov
*.srt
*.xlsx


# ──────────────────────────────────────
# 🔴 Whisper 모델 파일 (수백 MB)
# ──────────────────────────────────────
*.pt
*.bin
models/


# ──────────────────────────────────────
# 🔴 환경 설정 / 보안
# ──────────────────────────────────────
.env
.env.*
*.key
*.pem
secrets.json
config/local_settings.py


# ──────────────────────────────────────
# 🔴 IDE / 에디터 설정
# ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db


# ──────────────────────────────────────
# 🔴 가상환경
# ──────────────────────────────────────
venv/
.venv/
env/
ENV/


# ──────────────────────────────────────
# 🔴 PyInstaller 빌드 결과물
# ──────────────────────────────────────
dist/
build/
*.spec


# ──────────────────────────────────────
# 🔴 로그 파일
# ──────────────────────────────────────
*.log
logs/


# ──────────────────────────────────────
# 🟡 임시 다운로드 폴더
# ──────────────────────────────────────
yt_download_*/
tmp/
temp/
